# SharedTerminal Enterprise — Environment Configuration
# Copy this to .env and customize for your deployment

# Server URL (required for self-hosted mode)
SERVER_URL=https://terminal.yourcompany.com

# Port (default: 3000)
PORT=3000

# Docker image for sandbox containers
DOCKER_IMAGE=sharedterminal:latest

# Container resource limits
CONTAINER_MEMORY_LIMIT=536870912    # 512MB
CONTAINER_PID_LIMIT=256

# Session timeout (1 hour default)
SESSION_IDLE_TIMEOUT_MS=3600000

# Feature flags
RECORDING_ENABLED=true
DLP_ENABLED=true
TUNNEL_ENABLED=false

# ─── SSO / OIDC Configuration ───────────────────────────────
# Set SSO_ENABLED=true to require SSO authentication.
# Supports: Okta, Microsoft Entra ID, Google Workspace, Auth0,
#           Keycloak, OneLogin, or any OIDC-compliant IdP.

SSO_ENABLED=false

# Your IdP's OIDC issuer URL (the base URL, not the .well-known endpoint)
# Examples:
#   Okta:            https://yourcompany.okta.com
#   Microsoft Entra: https://login.microsoftonline.com/{tenant-id}/v2.0
#   Google:          https://accounts.google.com
#   Auth0:           https://yourcompany.auth0.com
#   Keycloak:        https://keycloak.yourcompany.com/realms/your-realm
SSO_ISSUER_URL=

# OAuth2 client credentials (register SharedTerminal as an app in your IdP)
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# Callback URL (must match what's registered in your IdP)
SSO_CALLBACK_URL=https://terminal.yourcompany.com/api/auth/sso/callback

# Restrict access to specific email domains (comma-separated)
# Leave empty to allow any authenticated user from the IdP
SSO_ALLOWED_DOMAINS=yourcompany.com

# Allow password-based join as fallback when SSO is enabled
# Set to "false" to enforce SSO-only access
SSO_PASSWORD_FALLBACK=true
